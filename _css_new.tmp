@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;600;700&display=swap');

:root {
    --fm-bg: #f8fafc;
    --fm-bg-raised: #f1f5f9;
    --fm-bg-card: #ffffff;
    --fm-bg-hover: #f1f5f9;
    --fm-bg-input: #ffffff;
    --fm-border: #e2e8f0;
    --fm-border-light: #f1f5f9;
    --fm-text: #0f172a;
    --fm-text-secondary: #475569;
    --fm-text-muted: #94a3b8;
    --fm-primary: #0d9488;
    --fm-primary-dim: #0f766e;
    --fm-primary-light: #ccfbf1;
    --fm-primary-glow: rgba(13,148,136,0.10);
    --fm-primary-ghost: rgba(13,148,136,0.04);
    --fm-success: #059669;
    --fm-warning: #d97706;
    --fm-danger: #dc2626;
    --fm-info: #7c3aed;
